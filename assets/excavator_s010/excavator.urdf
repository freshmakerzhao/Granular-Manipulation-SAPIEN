      </geometry>
    </collision>
  </link>
  <joint name="j1_swing" type="continuous">
    <origin xyz="0 0 0.072" rpy="0 0 0" />
    <parent link="1_base" />
    <child link="2_swing" />
    <axis xyz="0 0 -1" />
